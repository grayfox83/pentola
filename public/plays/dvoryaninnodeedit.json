{
  "title": "Дворянин и Ноде",
  "desc": "Редакция по сценарию в libretto/Dvoryanin_i_node.docx.",
  "roles": [
    {
      "id": 0,
      "name": "Господин"
    },
    {
      "id": 1,
      "name": "Дама"
    },
    {
      "id": 2,
      "name": "Ноде"
    },
    {
      "id": 3,
      "name": "Лизон"
    }
  ],
  "lines": [
    {
      "roleId": 0,
      "line": [
        {
          "s": "(В крестьянском доме. Лизон подметает, входит Господин и начинает ухаживания).",
          "action": true
        },
        {
          "s": "(изнеженно и высокомерно)",
          "action": true
        },
        {
          "s": "Флоринда, милая моя!"
        },
        {
          "s": "Скажу я, страсти не тая..."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Мой господин, сказать должна, Что Лизаветой крещена."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Ах, то галантнейший сеньяль."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Не понимаю."
        },
        {
          "s": "Вот печаль!"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "В амурах надобна вуаль..."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Немаловажная деталь."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Зовется это — пастораль."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "(в сторону)",
          "action": true
        },
        {
          "s": "Еще и так?"
        },
        {
          "s": "Не знала, жаль!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(Появляется Ноде.)",
          "action": true
        },
        {
          "s": "Лизон!"
        },
        {
          "s": "(замечает Г.)",
          "action": true
        },
        {
          "s": "..."
        },
        {
          "s": "Простите, господин."
        },
        {
          "s": "Какая честь!"
        },
        {
          "s": "С каких причин?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(с досадой)",
          "action": true
        },
        {
          "s": "Я в этих кущах, дня на склоне, Служил Диане, как Адонис."
        },
        {
          "s": "Охотой сладкой утомлен..."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(в сторону)",
          "action": true
        },
        {
          "s": "Охотился."
        },
        {
          "s": "На наших жен."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "И, жаждой Бахуса томим..."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(сдерживаясь)",
          "action": true
        },
        {
          "s": "Эх, мне бы по-простому с ним..."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Поскольку тОмит летний зной..."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Лизон!"
        },
        {
          "s": "На кухню, за водой!"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(Лизон убегает, Г. разочарован)",
          "action": true
        },
        {
          "s": "Мой друг, просить хочу и вас..."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(неловко кланяясь)",
          "action": true
        },
        {
          "s": "Да ваша просьба — мне приказ."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Стал Эол хладным и сырым..."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(в сторону)",
          "action": true
        },
        {
          "s": "Страдал тут кто-то от жары..."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Подбросьте хвороста в очаг."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(кланяясь)",
          "action": true
        },
        {
          "s": "Бегу."
        },
        {
          "s": "(в сторону)",
          "action": true
        },
        {
          "s": "Да как бы вам не так!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "(входит Лизон с кувшином, поит Г.)",
          "action": true
        },
        {
          "s": "Вот, сударь, прямо с родника."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Ах, ваша нежная рука..."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "(\"простодушно не замечает\" намеков)",
          "action": true
        },
        {
          "s": "Вы пейте."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(с трудом пьет, достает монетку)",
          "action": true
        },
        {
          "s": "Вот вам за труды..."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Как будто жалко мне воды!"
        },
        {
          "s": "(но деньги берет)",
          "action": true
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(с трудом пьет)",
          "action": true
        },
        {
          "s": "Ах, не жалея нежных сил..."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Вы ПЕЙТЕ."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(с отвращением)",
          "action": true
        },
        {
          "s": "Я уже допил."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "(издевательски-любезно)",
          "action": true
        },
        {
          "s": "Еще кувшин?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(поперхнувшись)",
          "action": true
        },
        {
          "s": "Благодарим."
        },
        {
          "s": "Иною жаждой я томим."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "(входит Н. из-за спины Г. и дожидается момента)",
          "action": true
        },
        {
          "s": "(\"догадываясь\")",
          "action": true
        },
        {
          "s": "Хотите, сударь..."
        },
        {
          "s": "молока?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(в испуге)",
          "action": true
        },
        {
          "s": "Не надо!"
        },
        {
          "s": "Не хочу пока."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "А..."
        },
        {
          "s": "кислых щей?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(поперхнувшись)",
          "action": true
        },
        {
          "s": "Благодарю."
        },
        {
          "s": "(падая на колено)",
          "action": true
        },
        {
          "s": "Сердечной жаждой я горю!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(сзади, кричит на ухо Г.)",
          "action": true
        },
        {
          "s": "Горит!!!"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(испуганно вздрогнув, вскакивает)",
          "action": true
        },
        {
          "s": "О чем вы?!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Как — о чем?"
        },
        {
          "s": "(пародируя \"высокий штиль\")",
          "action": true
        },
        {
          "s": "\"Очаг пылает горячо\"."
        },
        {
          "s": "И жарче развести могу."
        },
        {
          "s": "Ступайте, сударь, к очагу."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(\"заботливо\" тащит Г. к огню, встает между ним и женой)",
          "action": true
        },
        {
          "s": "(явно страдая от жары)",
          "action": true
        },
        {
          "s": "Ах, что-то я разгорячен..."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Водички надобно еще?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Еще дровишек?"
        },
        {
          "s": "Мех для рук?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(переходит к высокомерному хамству)",
          "action": true
        },
        {
          "s": "Нет."
        },
        {
          "s": "Я придумал."
        },
        {
          "s": "Вот что, друг: Я у огня немного взмок,"
        },
        {
          "s": "А в замке позабыл платок."
        },
        {
          "s": "Ты у жены его спроси"
        },
        {
          "s": "И мне прилежно принеси."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Сейчас исполню, видит Бог."
        },
        {
          "s": "Жена!"
        },
        {
          "s": "Давай сюда платок."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Болван!"
        },
        {
          "s": "Платок мне нужен — МОЙ."
        },
        {
          "s": "Ищи его с МОЕЙ женой."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(угрюмо)",
          "action": true
        },
        {
          "s": "Свою жену вы, ей-же-ей,"
        },
        {
          "s": "И сами спутали с моей."
        },
        {
          "s": "(Л. успокаивает и удерживает Н.)",
          "action": true
        },
        {
          "s": "Кому-то это на беду..."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(капризно)",
          "action": true
        },
        {
          "s": "Мне долго ждать еще?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(после тяжелой паузы)",
          "action": true
        },
        {
          "s": "Иду."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(Н. выходит)",
          "action": true
        },
        {
          "s": "(устало)",
          "action": true
        },
        {
          "s": "Флоринда, милая моя!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Елизавета."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Знаю я!"
        },
        {
          "s": "Моя высокая печаль..."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Постель."
        },
        {
          "s": "Ах, то есть — пастораль."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(входит Ноде с топором из-за спины Г.)",
          "action": true
        },
        {
          "s": "(пасторальным тоном)",
          "action": true
        },
        {
          "s": "Скажу я, страсти не тая..."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(Тоном Отелло)",
          "action": true
        },
        {
          "s": "Скажу я, страсти не тая..."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(вскакивает в ужасе, видит топор, шарахается прочь панически)",
          "action": true
        },
        {
          "s": "О Боже мой!"
        },
        {
          "s": "Что вижу я?!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(спокойно)",
          "action": true
        },
        {
          "s": "Дык, я — Ноде."
        },
        {
          "s": "Я вам знаком."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "А что Вы, сударь..."
        },
        {
          "s": "с топором?!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Решил, чтоб время не терять, Дровишек по пути набрать."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(немного успокаиваясь, но отодвинувшись от Лизон и Ноде на почтительное расстояние)",
          "action": true
        },
        {
          "s": "Дровишек?"
        },
        {
          "s": "Ладно."
        },
        {
          "s": "Хорошо."
        },
        {
          "s": "А только что ты не ушел?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Мне в замок не войти сейчас, Не давши знак, что я — от вас."
        },
        {
          "s": "(Г-н озадачен; Ноде подходит к Лизон)",
          "action": true
        },
        {
          "s": "(жене, тихо)",
          "action": true
        },
        {
          "s": "Мне нужен повод, хоть какой, Для разговора с госпожой."
        },
        {
          "s": "Но только повод, ты смотри!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Ты что, мой милый, говоришь!"
        },
        {
          "s": "Не сомневайся зря в жене:"
        },
        {
          "s": "Лишь только ты и нужен мне."
        },
        {
          "s": "(кокетливо прижимается к Г-ну)",
          "action": true
        },
        {
          "s": "."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(осмелев)",
          "action": true
        },
        {
          "s": "Со знаком мы поступим так:"
        },
        {
          "s": "Вот этот перстень — верный знак."
        },
        {
          "s": "(передает перстень через Л.)",
          "action": true
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(разглядывая перстень хозяйственно)",
          "action": true
        },
        {
          "s": "Благодарю вас, господин:"
        },
        {
          "s": "Нам хватит денег до седин."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(поняв Ноде, наконец)",
          "action": true
        },
        {
          "s": "Но..."
        },
        {
          "s": "ретриманд необходим!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(Лизон кокетливо улыбается Господину)",
          "action": true
        },
        {
          "s": "(притворяясь тугоухим и непонимающим)",
          "action": true
        },
        {
          "s": "Чего-чего?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Иди."
        },
        {
          "s": "Черт с ним!"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(Ноде, уходя, оглядывается, обменивается взглядом с женой)",
          "action": true
        },
        {
          "s": "(спохватившись)",
          "action": true
        },
        {
          "s": "Ноде!"
        },
        {
          "s": "Еще один ПРИКАЗ:"
        },
        {
          "s": "Молчи о виденном сейчас."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(Н. кланяется и уходит, чуть ли не скрипя зубами.)",
          "action": true
        },
        {
          "s": "(облегченно)",
          "action": true
        },
        {
          "s": "Как хорошо, что он ушел."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Вы правы, это — хорошо."
        },
        {
          "s": "(изображает испуг)",
          "action": true
        },
        {
          "s": "Он может, надо вам сказать,"
        },
        {
          "s": "(изображает движение топором)",
          "action": true
        },
        {
          "s": "Изрядно дров поналомать."
        },
        {
          "s": "(лукаво)",
          "action": true
        },
        {
          "s": "А если вдруг вернется он?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "(плохо скрывая страх)",
          "action": true
        },
        {
          "s": "Здесь воздух дУшен и..."
        },
        {
          "s": "душОн."
        },
        {
          "s": "Дождусь я встречи на лугу."
        },
        {
          "s": "(поспешно выходит)",
          "action": true
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Ну, ждите..."
        },
        {
          "s": "(в сторону)",
          "action": true
        },
        {
          "s": "Как же, побегу!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Полна предчувствий и страстей:"
        },
        {
          "s": "От мужа долго нет вестей..."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(Входит Ноде, кланяясь)",
          "action": true
        },
        {
          "s": "Мой господин, а ваш супруг,"
        },
        {
          "s": "Мне порученье выдал вдруг:"
        },
        {
          "s": "Бежать к вам в замок за платком."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "(беспокоясь)",
          "action": true
        },
        {
          "s": "А что случилось с муженьком?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "(нарочито мнется)",
          "action": true
        },
        {
          "s": "Да как сказать без лишних слов..."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "(с тревогой)",
          "action": true
        },
        {
