{
  "title": "Дворянин и Ноде",
  "desc": "(Le Gentilhomme et Naudet) Фарс начала XVI в.; оригинал по изданию в сборнике.",
  "roles": [
    {
      "id": 0,
      "name": "Лизон"
    },
    {
      "id": 1,
      "name": "Ноде"
    },
    {
      "id": 2,
      "name": "Дворянин"
    },
    {
      "id": 3,
      "name": "Дама"
    }
  ],
  "lines": [
    {
      "roleId": 0,
      "line": [
        {
          "s": "Уж так хитер супружник мой!"
        },
        {
          "s": "Он всем моим делам помеха."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Никак, жена пришла домой?"
        },
        {
          "s": "Послушай, это ль не потеха?"
        },
        {
          "s": "Ей-ей, сейчас помру от смеха:"
        },
        {
          "s": "Сеньор наш ходит по ночам"
        },
        {
          "s": "Блудить, забывши стыд и срам."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Да полно врать-то, сумасброд!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Ну, кто другой, быть может, врет,"
        },
        {
          "s": "А я так это все воочью"
        },
        {
          "s": "Видал."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Когда же?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Нынче ночью."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "И где?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Да в ближнем сосняке,"
        },
        {
          "s": "От нас совсем невдалеке."
        },
        {
          "s": "Бабенка с ним была одна."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "И разглядел ты, кто она?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Обоих видел я прекрасно."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Ты на меня грешишь, несчастный!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Я так не говорил, Лизон!"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Когда б тебя услышал он,"
        },
        {
          "s": "Сейчас бы засадил в тюрьму."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Но ты ж не передашь ему?"
        },
        {
          "s": "Должны стоять мы друг за друга:"
        },
        {
          "s": "Ты как-никак моя супруга."
        },
        {
          "s": "Ведь он меня прикончит вмиг."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "А ты не распускай язык."
        },
        {
          "s": "И добр, и щедр сеньор у нас;"
        },
        {
          "s": "Придя к нам в гости, всякий раз"
        },
        {
          "s": "Тебе он ставит угощенье."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Ты ждешь, выходит, посещенья?"
        },
        {
          "s": "Ну что ж, пожалуй, я не прочь"
        },
        {
          "s": "Сеньору за столом помочь."
        },
        {
          "s": "Спекла бы ты ему пирог."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "А ты бы мне, балбес, помог:"
        },
        {
          "s": "Сходил бы в лес, принес бы дров."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Иду."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Я страстную любовь"
        },
        {
          "s": "Питаю к нежной Ализон,"
        },
        {
          "s": "Я так ее красой пленен,"
        },
        {
          "s": "Таких исполнен пылких чувств,"
        },
        {
          "s": "Что лишь с охоты возвращусь,"
        },
        {
          "s": "Как тотчас направляюсь к ней."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Наш господин-то у дверей."
        },
        {
          "s": "Как будто бес его пригнал."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Привет вам!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Я ведь вас признал."
        },
        {
          "s": "Ну что, сеньор к нам в дом войдет?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Молчи!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Не затыкай мне рот!"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Разговорился, обормот!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Ноде, послушай-ка меня:"
        },
        {
          "s": "Садись на моего коня"
        },
        {
          "s": "И выезди его шажком."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Я поведу его пешком"
        },
        {
          "s": "К ручью, чтоб он попил водицы."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "[Он этак может запалиться.]"
        },
        {
          "s": "Сейчас нельзя поить его!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "(садясь в седло).",
          "action": true
        },
        {
          "s": "Конь вроде ошалел. С чего"
        },
        {
          "s": "Так вскидывает крупом он?"
        },
        {
          "s": "Ой-ой! Похоже, легион"
        },
        {
          "s": "Слепней его кусает в зад."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Лизон, я несказанно рад,"
        },
        {
          "s": "Что свиделся с тобой опять!"
        },
        {
          "s": "Скорее дай тебя обнять."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Не стану вам сопротивляться."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "В седле не смог я удержаться,"
        },
        {
          "s": "Слетел; ваш конь, клянусь, шальной."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Лизон, твой муж следит за мной..."
        },
        {
          "s": "Ноде, поставь-ка лошадь в хлев."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Лизон, поставь скорее хлеб"
        },
        {
          "s": "И что-нибудь еще на стол."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Ишь, аппетит к Ноде пришел."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Дурь в мужике всегда видна."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Не выпьете ль, сеньор, вина?"
        },
        {
          "s": "Какое больше вам по нраву?"
        },
        {
          "s": "Чье лучше брать?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Не знаю, право."
        },
        {
          "s": "Возьми в таверне «Подо львом»."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Бегу!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Ну вот мы и вдвоем."
        },
        {
          "s": "Он здесь нам вовсе ни к чему."
        },
        {
          "s": "Я быстренько камзол сниму,"
        },
        {
          "s": "Чтобы с тобою порезвиться."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Да, надо нам поторопиться —"
        },
        {
          "s": "Он скоро прибежит назад."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "А вы дадите мне деньжат,"
        },
        {
          "s": "Иль записать на счетец вам?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Два су сейчас тебе я дам,"
        },
        {
          "s": "Бери их и беги скорей,"
        },
        {
          "s": "А поминать меня не смей."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Лечу. Меня уже здесь нет."
        },
        {
          "s": "Брать белое или кларет?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Да что понравится, бери."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Уйдешь ты, черт тебя дери?"
        },
        {
          "s": "Вино здесь будет наконец?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Иди, милейший."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Ишь, хитрец!"
        },
        {
          "s": "Уж так он ловок, просто страх —"
        },
        {
          "s": "Всегда оставит в дураках,"
        },
        {
          "s": "Но с ним еще сквитаюсь я."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "О, скоро ль, нежная моя,"
        },
        {
          "s": "Нагая ляжешь ты со мной?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Ноде сейчас придет домой,"
        },
        {
          "s": "Так вы б ему работу дали,"
        },
        {
          "s": "Услали бы куда подале,"
        },
        {
          "s": "А то ведь наше вожделенье"
        },
        {
          "s": "Останется без утоленья:"
        },
        {
          "s": "Все время он толчется здесь."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Ну, у меня в запасе есть"
        },
        {
          "s": "Один прехитрый изворот:"
        },
        {
          "s": "Надолго твой супруг уйдет."
        },
        {
          "s": "Я знаю, что мне сделать надо."
        },
        {
          "s": "Моя жена болтать с ним рада:"
        },
        {
          "s": "Изрядно он смешит ее."
        },
        {
          "s": "[Так вот, послание свое"
        },
        {
          "s": "Жене с Ноде я отошлю,"
        },
        {
          "s": "А сам с тобою пошалю],"
        },
        {
          "s": "Мне прямо невтерпеж, мой свет."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Но чтоб не выдать наш секрет,"
        },
        {
          "s": "Отдайте муженьку приказ"
        },
        {
          "s": "Не говорить, что вы у нас,"
        },
        {
          "s": "Иль будет госпоже обидно."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "И правда."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Никого не видно."
        },
        {
          "s": "Хлебну-ка прямо из кувшина —"
        },
        {
          "s": "Я был бы сущая дубина,"
        },
        {
          "s": "Коль не отведал бы винца."
        },
        {
          "s": "Встречайте вашего гонца!"
        },
        {
          "s": "Вот и вино."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Ну как оно?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Такого не пил я давно."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Ну так давай его в ведро"
        },
        {
          "s": "С водой."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Не лучше ли в нутро?"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Молчи и делай, что велят!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Пусть тут же провалюсь я в ад,"
        },
        {
          "s": "Коль прежде третью часть свою"
        },
        {
          "s": "Законную не отопью!"
        },
        {
          "s": "А в воду пустим вашу долю."
        },
        {
          "s": "Ну-с, я вина напился вволю..."
        },
        {
          "s": "В ведро теперь все, что осталось,"
        },
        {
          "s": "Пускай там охладится малость,"
        },
        {
          "s": "Пока вы пить не захотели."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "А я бы выпил, в самом деле."
        },
        {
          "s": "Налей."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Вот я вам зачерпнул."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Да ты вино в ведро плеснул!"
        },
        {
          "s": "Ты, верно, тронулся, Ноде?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Вино, как велено, в воде —"
        },
        {
          "s": "Так приказал мне господин."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Прохвост, ведь я тебе кувшин"
        },
        {
          "s": "Поставить в воду приказал."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Нет, про кувшин я не слыхал;"
        },
        {
          "s": "Сказали вы: вино — в ведро."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Увы, загублено добро,"
        },
        {
          "s": "И нечего теперь нам пить."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Поди сюда!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Хотите бить?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Да нет, на этот раз прощу."
        },
        {
          "s": "Письмо с тобой послать хочу."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Бегу!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Вот дурья голова!"
        },
        {
          "s": "Ты выслушай меня сперва:"
        },
        {
          "s": "Снеси письмо жене моей,"
        },
        {
          "s": "Но только говорить не смей"
        },
        {
          "s": "О том, что я сижу у вас."
        },
        {
          "s": "Скажи ей вот что: мол, сейчас"
        },
        {
          "s": "Молиться в церковь я пошел."
        },
        {
          "s": "Да пусть накроют в доме стол"
        },
        {
          "s": "И самым лучшим до отвала"
        },
        {
          "s": "Тебя накормят. Но сначала"
        },
        {
          "s": "В конюшню отведешь коня."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "За стол посадят, что ль, меня?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "В хлеву не кормим мы людей."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Я все запомнил. Значит, ей"
        },
        {
          "s": "[Письмо я должен отнести,"
        },
        {
          "s": "Коня в конюшню отвести,"
        },
        {
          "s": "Соврать, что вы пошли молиться.]"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Лизон, давай скорей любиться,"
        },
        {
          "s": "Теперь ложиться можно смело!"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Но, сударь, я бы не хотела,"
        },
        {
          "s": "Чтоб нас сосед застал за этим —"
        },
        {
          "s": "Ведь мы его и не заметим."
        },
        {
          "s": "Мы в задней комнатушке ляжем."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "А я и не подумал даже!"
        },
        {
          "s": "Да, чтоб не помешали нам,"
        },
        {
          "s": "Пойдем побалуемся там."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Я полагаю, конь умен"
        },
        {
          "s": "И сам найдет дорогу он."
        },
        {
          "s": "Ступай, а я приду потом."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "В душе ужасное смятенье:"
        },
        {
          "s": "Уж не случилась ли беда?"
        },
        {
          "s": "Без мужа конь пришел сюда."
        },
        {
          "s": "Нет, вот и муж идет домой."
        },
        {
          "s": "Ну слава богу, ты живой!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Я стал сеньором, бог ты мой!"
        },
        {
          "s": "Встречают-то людей по платью:"
        },
        {
          "s": "Смени одежку — станешь знатью."
        },
        {
          "s": "Да, я — сеньор, имею честь!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "О боже, кто же это здесь?"
        },
        {
          "s": "Ноде? Ну да, его лицо..."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Сеньор прислал вам письмецо."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Немедленно ответствуй мне:"
        },
        {
          "s": "Где муж мой?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "На моей жене."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Тебя не поняла я что-то."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Сеньор сказал, что, мол, с охоты"
        },
        {
          "s": "Придя, пошел он мессу слушать,"
        },
        {
          "s": "А мне у вас велел откушать:"
        },
        {
          "s": "Меня вы угостить должны."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Он, значит, у твоей жены?"
        },
        {
          "s": "Постой, а он не знает, что ли:"
        },
        {
          "s": "Сейчас все наши люди в поле."
        },
        {
          "s": "На стол кто будет подавать?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Людей не стоит с поля звать."
        },
        {
          "s": "Я гость, но заменю слугу"
        },
        {
          "s": "И сам на стол подать могу."
        },
        {
          "s": "Прошу ключи от погребов"
        },
        {
          "s": "И от кладовок..."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Нет, каков!"
        },
        {
          "s": "Еще вручи ему ключи!"
        },
        {
          "s": "Ну, так и быть уж, получи"
        },
        {
          "s": "Кусок вчерашнего паштета."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Ну что ж, спасибо и за это."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Однако не могу понять я,"
        },
        {
          "s": "Зачем свое он отдал платье"
        },
        {
          "s": "Тебе? Ведь ты его измял."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Да не давал он — сам я взял."
        },
        {
          "s": "Видать, спешил он и камзол,"
        },
        {
          "s": "Раздевшись, бросил к нам на стол."
        },
        {
          "s": "Я взял камзольчик со стола."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Теперь тебя я поняла:"
        },
        {
          "s": "К вам в гости заявился он,"
        },
        {
          "s": "Его там встретила Лизон,"
        },
        {
          "s": "Ты их покинул только что..."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Э, нет, рассказывать про то"
        },
        {
          "s": "Мне напрочь запретил сеньор!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Однако ты, Ноде, хитер!"
        },
        {
          "s": "А знает про камзол супруг?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "И не подозревает даже."
        },
        {
          "s": "Я уберег камзол от кражи:"
        },
        {
          "s": "У нас одно ворье вокруг."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "А он тебе идет, мой друг."
        },
        {
          "s": "Лизон тебя видала в нем?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Откуда же ей знать о том?"
        },
        {
          "s": "Нет! Занята Лизон была,"
        },
        {
          "s": "Понеже на спину легла"
        },
        {
          "s": "Там, в задней комнатке у нас."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Я опасаюсь, что сейчас"
        },
        {
          "s": "Твой господин лежит с ней рядом."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Да нет, на ней и кверху задом —"
        },
        {
          "s": "Я это видел в щелку двери."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Исусе! Верю и не верю."
        },
        {
          "s": "Скажи, а что он делал с нею?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Нет, я рассказывать не смею —"
        },
        {
          "s": "Ведь мне сеньор задаст такого!.."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Я не скажу ему ни слова."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Э, нет, ищите дураков!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Хлебни-ка парочку глотков"
        },
        {
          "s": "И расскажи мне обо всем."
        },
        {
          "s": "Ведь мы же здесь с тобой вдвоем."
        },
        {
          "s": "Как он узнает? Говори!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Я предпочел бы раза три"
        },
        {
          "s": "На вас все это показать,"
        },
        {
          "s": "Чем хоть словечко вам сказать:"
        },
        {
          "s": "Ведь это тайна как-никак."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Не сможешь: в этом ты дурак."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Ну, госпожа, уж мне ль не смочь!"
        },
        {
          "s": "Да я Лизон раз восемь в ночь,"
        },
        {
          "s": "Порой гоняю до зари."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Ой нет, пожалуйста, не ври;"
        },
        {
          "s": "Ты глуп для этаких утех."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Иной дурак умнее всех."
        },
        {
          "s": "Вот если бы для испытанья"
        },
        {
          "s": "Вы отдали мне приказанье,"
        },
        {
          "s": "Чтоб я вам сделав то, что он"
        },
        {
          "s": "Сейчас там делает Лизон,"
        },
        {
          "s": "Я согласился б, черт возьми!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Что ж, обними меня, прижми"
        },
        {
          "s": "Да покажи мне свой запал."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Сеньор камзол сначала снял,"
        },
        {
          "s": "Вот так вот взял ее в объятья,"
        },
        {
          "s": "Потом, на ней задравши платье,"
        },
        {
          "s": "Вошел в распахнутую дверь…"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Не скоро он придет теперь."
        },
        {
          "s": "Нет, я придумал очень ловко,"
        },
        {
          "s": "Ей-ей, изрядная уловка."
        },
        {
          "s": "Его там потчует жена,"
        },
        {
          "s": "А уж гостей принять она,"
        },
        {
          "s": "Клянусь, умеет, как никто."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Я вот подумала про что:"
        },
        {
          "s": "Ноде мой больно пить горазд,"
        },
        {
          "s": "А как напьется он, то враз"
        },
        {
          "s": "Теряет память и рассудок;"
        },
        {
          "s": "Я опасаюсь, кроме шуток,"
        },
        {
          "s": "Что наш секрет он выдаст ей."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Как — выдаст? Тысяча чертей!"
        },
        {
          "s": "Большая мне грозит беда..."
        },
        {
          "s": "Я ж сам послал его туда,"
        },
        {
          "s": "Чтоб он болтал перед женой!"
        },
        {
          "s": "Вернуться надо мне домой,"
        },
        {
          "s": "Но нет камзола моего."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "А где снимали вы его?"
        },
        {
          "s": "Здесь? А куда, раздевши, клали?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Его, я думаю, украли,"
        },
        {
          "s": "Ведь я его оставил тут;"
        },
        {
          "s": "Какой-нибудь негодный плут"
        },
        {
          "s": "Должно вошел и спер камзол."
        },
        {
          "s": "Зачем его не захватила?"
        },
        {
          "s": "Я на тебя за это зол."
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Ах сударь до того ли было:"
        },
        {
          "s": "Вы так ретивы и так страстны"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Камзол пропал мне это ясно"
        },
        {
          "s": "Боюсь жена задаст мне жару"
        },
        {
          "s": "Известно беды ходят парой."
        },
        {
          "s": "Ждать надо новую беду"
        },
        {
          "s": "Ну что ж Лизон прощай. Пойду"
        }
      ]
    },
    {
      "roleId": 0,
      "line": [
        {
          "s": "Ступайте, сударь. До свиданья."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Я ваше выполнил желанье:"
        },
        {
          "s": "Вот так сеньор с моей женой"
        },
        {
          "s": "Игрался."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "О, клянусь душой,"
        },
        {
          "s": "Весьма довольна я тобой:"
        },
        {
          "s": "Ты превосходно знаешь дело."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Так мне ж Лизон всегда велела,"
        },
        {
          "s": "Чтоб я ее брал только с тыла."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Ах, если б ты сеньором стал,"
        },
        {
          "s": "А он — Ноде, мне б слаще было."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Уж я бы так вас услаждал!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Молчи об этом как могила,"
        },
        {
          "s": "Тогда наряд получишь новый."
        },
        {
          "s": "Еще, голубчик, дай мне слово,"
        },
        {
          "s": "Что, как заявится к вам он,"
        },
        {
          "s": "Придешь и мне покажешь снова,"
        },
        {
          "s": "Что делает он там с Лизон."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Ну что ж, мне полный есть резон,"
        },
        {
          "s": "Коль новый получу наряд."
        },
        {
          "s": "Но гляньте, госпожа, назад:"
        },
        {
          "s": "Сюда идет сеньор Ноде."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Ага, явился ты. А где,"
        },
        {
          "s": "Скажи, оставил ты камзол?"
        },
        {
          "s": "Мне помнится, ты в нем ушел,"
        },
        {
          "s": "А возвратился налегке."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Да скинул я его в леске,"
        },
        {
          "s": "Чтоб поскорей домой прийти."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Врет, чтоб мне с места не сойти!"
        },
        {
          "s": "Камзольчик я надел, чтоб вор"
        },
        {
          "s": "Его не спер, пока сеньор"
        },
        {
          "s": "Вовсю с моей женой игрался."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Мужлан бесчестный, ты заврался!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Нет, он честнейший из людей!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "А что ж вы делали на ней?"
        },
        {
          "s": "Я видел, как он сверху лег."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Так вот каков ты, муженек!"
        },
        {
          "s": "Сколь это гнусно, сколь ужасно!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "И ты поверила? Напрасно:"
        },
        {
          "s": "Мужик придурковат и лжив."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Дама. Вот почему ты стал ленив:"
        },
        {
          "s": "Чужой возделываешь сад."
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Да я ни в чем не виноват"
        },
        {
          "s": "И чист перед тобой, поверь!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "(хохочет).",
          "action": true
        },
        {
          "s": "Вы не сеньор — Ноде теперь!"
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Ужели так нехороша"
        },
        {
          "s": "Я для тебя?"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Вы, госпожа,"
        },
        {
          "s": "Прекрасны и внутри и с виду."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Какую я терплю обиду!"
        },
        {
          "s": "Ты тешишься на стороне,"
        },
        {
          "s": "Потом являешься ко мне"
        },
        {
          "s": "И сочиняешь небылицы."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "У госпожи одна вещица,"
        },
        {
          "s": "Совсем как у Лизон, сладка"
        },
        {
          "s": "И точно так же глубока,"
        },
        {
          "s": "И даже мех у них похож."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "Молчи, болван! Зачем ты врешь?"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Э, нет! Изволь-ка говори!"
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Ведь я и раз, и два, и три"
        },
        {
          "s": "Ее испробовал — все то же,"
        },
        {
          "s": "Внутри ль, снаружи — все похоже,"
        },
        {
          "s": "И разницы нет никакой"
        },
        {
          "s": "Между Лизон и госпожой;"
        },
        {
          "s": "Устройство на один фасон"
        },
        {
          "s": "У госпожи и у Лизон."
        },
        {
          "s": "И я шалить не прочь с любой —"
        },
        {
          "s": "С моей Лизон иль с госпожой."
        },
        {
          "s": "Так выбирайте без препон"
        },
        {
          "s": "Меж госпожою и Лизон:"
        },
        {
          "s": "Хоть с этой можете, хоть с той —"
        },
        {
          "s": "С моей Лизон иль с госпожой."
        },
        {
          "s": "Хотите — обменяем жен,"
        },
        {
          "s": "Иль можем жить одной семьей"
        },
        {
          "s": "И с госпожою и с Лизон."
        }
      ]
    },
    {
      "roleId": 3,
      "line": [
        {
          "s": "С ума, должно быть, спятил он!"
        }
      ]
    },
    {
      "roleId": 2,
      "line": [
        {
          "s": "Уж я работкою ночной"
        },
        {
          "s": "Занялся б с каждой из сластен,"
        },
        {
          "s": "Сперва с женой, потом с Лизон,"
        },
        {
          "s": "С твоей Лизон, с моей женой,"
        },
        {
          "s": "Но, поглядев со всех сторон,"
        },
        {
          "s": "Решил не спорить я с тобой"
        },
        {
          "s": "И лезть не стану на рожон:"
        },
        {
          "s": "Ведь ляжешь ты с моей женой,"
        },
        {
          "s": "Коль лягу я с твоей Лизон."
        }
      ]
    },
    {
      "roleId": 1,
      "line": [
        {
          "s": "Не поднимал бы я трезвон"
        },
        {
          "s": "И не полез бы к вам со спором,"
        },
        {
          "s": "Ноде вам быть или сеньором,"
        },
        {
          "s": "Но быть обоими зараз"
        },
        {
          "s": "Честь, право, малая для вас."
        },
        {
